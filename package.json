{
  "name": "swiftcare-backend",
  "version": "1.0.0",
  "description": "SwiftCare clinic management API",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
